@model DoManager.Models.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Реєстрація - To-Do List Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/Account(Register).css" />
</head>
<body>

    <div class="login-card">
        <span class="project-title">To-Do List Manager</span>
        <h2>Реєстрація</h2>
        <p class="sub-text">Введіть Ваші дані, щоб створити свій обліковий запис</p>

        <form asp-action="Register" asp-controller="Account" method="post" id="registrationForm" autocomplete="off" novalidate>

            <input type="email" name="fake_email" style="opacity: 0; position: absolute; top: -9999px; z-index: -1;" tabindex="-1" aria-hidden="true" />
            <input type="password" name="fake_password" style="opacity: 0; position: absolute; top: -9999px; z-index: -1;" tabindex="-1" aria-hidden="true" />

            <div class="input-group-custom">
                <label class="form-label">Електронна пошта</label>
                <input asp-for="Email" id="email" class="form-control-custom" placeholder="v@example.com" required autocomplete="off" />
                <div id="email-error" class="error-hint">Пошта обов'язкова або має невірний формат</div>
            </div>

            <div class="input-group-custom">
                <label class="form-label">Повне ім'я та прізвище</label>
                <input asp-for="FullName" id="fullName" class="form-control-custom" placeholder="Валерія Сорокіна" required />
                <div id="name-error" class="error-hint">Будь ласка, вкажіть ваше ПІБ</div>
            </div>

            <div class="input-group-custom">
                <label class="form-label">Пароль</label>
                <input asp-for="Password" id="pass1" type="password" class="form-control-custom" placeholder="Введіть пароль" required autocomplete="new-password" />
                <i class="bi bi-eye password-toggle" onclick="togglePass('pass1', this)"></i>
                <div id="pass1-error" class="error-hint">Пароль є обов'язковим</div>
            </div>

            <div class="input-group-custom">
                <label class="form-label">Підтвердження</label>
                <input asp-for="ConfirmPassword" id="pass2" type="password" class="form-control-custom" placeholder="Повторіть пароль" required autocomplete="new-password" />
                <i class="bi bi-eye password-toggle" onclick="togglePass('pass2', this)"></i>
                <div id="pass2-error" class="error-hint">Паролі не збігаються!</div>
            </div>

            <div asp-validation-summary="All" class="server-errors"></div>

            <button type="submit" id="submitBtn" class="login-btn" disabled>Зареєструватися</button>

            <div class="register-link">
                Вже є акаунт? <a asp-action="Login">Авторизація</a>
            </div>
        </form>
    </div>
    <script src="~/js/account-register.js"></script>
</body>
</html>